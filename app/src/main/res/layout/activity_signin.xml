<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E91E63"
    tools:context="Signin">


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❇️Signin❇️"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:background="@drawable/shape"
        android:textColor="#000"/>


    <!--        Below is  a card view-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="10dp"
        android:layout_margin="10dp"
        android:padding="10dp">

    <!--            Below is a linear that shall align contents vertically-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#2343"
        android:padding="10dp">

<!--        Below is the email EditText-->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="📧Enter Email Address"
            android:textColorHint="#800"
            android:textColor="#000"
            android:id="@+id/email"
            android:layout_margin="8dp"
            android:background="#EF9DF4"
            android:padding="11dp"/>


        <!--        Below is the password EditText-->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="🔑Enter your Password"
            android:textColorHint="#800"
            android:textColor="#000"
            android:id="@+id/password"
            android:layout_margin="8dp"
            android:background="#EF9DF4"
            android:padding="11dp"/>
<!--        Below is the signin button with its properties-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👮 Signin"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="50dp"
            android:layout_marginRight="50dp"
            android:layout_marginTop="30dp"
            android:background="#000"
            android:textColor="#000"
            android:backgroundTint="#33F40505"
            android:id="@+id/signinBtn" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dont Have an Account? Signup"
            android:textAlignment="center"
            android:textSize="25dp"
            android:layout_marginTop="25dp"
            android:textColor="#000"
            android:id="@+id/signuptxt"/>





    </LinearLayout>


</androidx.cardview.widget.CardView>


</LinearLayout>